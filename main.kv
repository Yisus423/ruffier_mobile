#:import txt_instruction instructions.txt_instruction

<InstrScr>
# Este es el Layout outer
MDBoxLayout:
    orientation:"vertical"
    padding:"25dp"
    spacing:"20dp"

    MDLabel:
        text: txt_instruction
        style: "HeadlineSmall"
        halign: "center"
        adaptative_height: True

    MDTextField:
        id: in_name
        multiline: False
        mode:"filled"
        size_hint_x: 0.9 # Un poco menos del 100% para que no toque los bordes
        pos_hint: {"center_x": 0.5}
        MDTextFieldHelperText:
            text: "Ingresa tú nombre"
            mode: "persistent"
        MDTextFieldLeadingIcon:
            icon:"account"

    MDTextField:
        id: in_age
        text: "7"
        multiline: False
        mode:"filled"
        size_hint_x: 0.9
        pos_hint: {"center_x": 0.5}
        MDTextFieldHelperText:
            text: "Ingresa tú edad"
            mode: "persistent"
        MDTextFieldLeadingIcon:
            icon:"account-clock"


    MDButton:
        style:"elevated"
        id: btn
        pos_hint: {"center_x":0.5}
        on_release: root.next()
        MDButtonText:
            text: "Iniciar"
